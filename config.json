{
  "pet_name": "KIBO",
  "ai_enabled": true,
  "activation_hotkey": "ctrl+k",
  "llm_provider": "auto",
  "ollama_base_url": "http://localhost:11434",
  "ollama_model": "llama3.2:3b",
  "groq_api_key_env": "GROQ_API_KEY",
  "groq_model": "llama-3.3-70b-versatile",
  "system_prompt": "You are KIBO, a small desktop companion that lives on the user's screen. Stay warm, playful, and concise (2-3 sentences unless asked for more). React naturally to what the user is doing. Never break character. Use emojis sparingly, only when they add real warmth.",
  "conversation_history_limit": 10,
  "tts_provider": "auto",
  "tts_enabled": true,
  "tts_rate": 175,
  "piper_model": "en_US-amy-medium",
  "piper_models_dir": "models/piper",
  "stt_model": "base.en",
  "stt_use_vad": true,
  "stt_vad_threshold": 0.5,
  "stt_min_silence_ms": 600,
  "recording_max_seconds": 8,
  "silence_threshold_seconds": 1.5,
  "whisper_model": "base.en",
  "memory_enabled": true,
  "memory_provider": "auto",
  "memory_max_facts": 200,
  "memory_top_k": 5,
  "memory_extraction_inline": true,
  "poll_interval_ms": 3000,
  "cpu_panic_threshold": 80,
  "battery_tired_threshold": 20,
  "sleepy_hour": 23,
  "studious_windows": [
    "Visual Studio Code",
    "code"
  ],
  "frame_rate_ms": 30,
  "window_size": [
    200,
    200
  ],
  "enable_speech_bubbles": true,
  "speech_bubble_timeout_ms": 5000,
  "opaque_fallback": false,
  "buddy_skin": "skales",
  "idle_action_interval_min_s": 30,
  "idle_action_interval_max_s": 60,
  "proactive_enabled": false,
  "quiet_hours_start": 22,
  "quiet_hours_end": 7,
  "notification_types": {
    "morning-greeting": true,
    "idle-checkin": true,
    "eod-summary": true,
    "cpu-panic": true,
    "battery-low": true,
    "meeting-reminder": true,
    "email-alert": true,
    "task-blocked": true
  },
  "calendar_provider": "none",
  "calendar_lookahead_minutes": 60,
  "clip_hotkey": "ctrl+alt+k"
}